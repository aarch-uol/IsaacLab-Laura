<?xml version="1.0" encoding="UTF-8" ?>
<!--
    FastDDS config for multi-machine ROS2 over Tailscale VPN.
    Machine B (this machine) communicates with Machine A at 100.71.76.112.

    Key changes vs default:
      - Binds to tailscale0 interface only (avoids LAN multicast leaking)
      - Disables multicast (not supported over Tailscale VPN)
      - Adds Machine A's Tailscale IP as an explicit unicast discovery peer
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>TailscaleUDP</transport_id>
            <type>UDPv4</type>
            <!-- Bind only to the Tailscale interface -->
            <interfaceWhiteList>
                <address>100.107.19.48</address>
            </interfaceWhiteList>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="tailscale_profile" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>TailscaleUDP</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
            <!-- Unicast discovery: point directly at Machine A's Tailscale IP -->
            <builtin>
                <metatrafficUnicastLocatorList>
                    <locator>
                        <udpv4>
                            <address>100.71.76.112</address>
                        </udpv4>
                    </locator>
                </metatrafficUnicastLocatorList>
                <initialPeersList>
                    <locator>
                        <udpv4>
                            <address>100.71.76.112</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
                <avoid_builtin_multicast>true</avoid_builtin_multicast>
            </builtin>
        </rtps>
    </participant>
</profiles>
